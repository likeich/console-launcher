[
  {
    "file": "NintendoDS.json",
    "insertAfter": "nds.com.dsemu.drastic",
    "player": {
      "name": "nds - Drastic (RG DS)",
      "uniqueId": "nds.com.dsemu.drastic.rgds",
      "description": "Supported extensions: bin, nds, rar, zip, 7z.",
      "acceptedFilenameRegex": "^(.*)\\.(?:bin|nds|rar|zip|7z)$",
      "amStartArguments": "-n com.dsemu.drastic/.DraSticActivity\n-d {file.path}\n--activity-clear-task\n--activity-clear-top",
      "killPackageProcesses": false,
      "killPackageProcessesWarning": true,
      "extra": ""
    }
  },
  {
    "file": "Windows.json",
    "insertAfter": "windows.app.gamenative.custom",
    "player": {
      "name": "windows - GameNative (PcGame)",
      "uniqueId": "windows.app.gamenative.pcgame",
      "description": "GameNative",
      "acceptedFilenameRegex": "^(.*)\\.(?:pcgame)$",
      "amStartArguments": "-a app.gamenative.LAUNCH_GAME\n -n app.gamenative/.MainActivity\n --ei app_id {tags.pcgame} --es game_source CUSTOM_GAME\n",
      "killPackageProcesses": false,
      "killPackageProcessesWarning": false,
      "extra": ""
    }
  }
]
